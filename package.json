{
  "name": "tutorial-with-svelte",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "format": "prettier --write .",
    "lint": "prettier --check ."
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "dependencies": {
    "playwright-core": "^1.52.0",
    "sharp": "^0.34.2"
  },
  "devDependencies": {
    "@mdi/js": "^7.4.47",
    "@sveltejs/adapter-node": "^5.5.4",
    "@sveltejs/kit": "^2.22.0",
    "@sveltejs/vite-plugin-svelte": "^6.0.0",
    "@types/luxon": "^3.7.1",
    "@types/node": "^22.10.5",
    "esbuild": "0.27.2",
    "ky": "^2.0.0",
    "luxon": "^3.7.2",
    "prettier": "^3.8.1",
    "prettier-plugin-svelte": "^3.5.1",
    "svelte": "^5.0.0",
    "svelte-check": "^4.0.0",
    "svelte-language-server": "^0.17.30",
    "typescript": "^5.9",
    "typescript-language-server": "^5.1.3",
    "vite": "^7.0.4"
  },
  "prettier": {
    "useTabs": false,
    "singleQuote": false,
    "trailingComma": "all",
    "printWidth": 100,
    "proseWrap": "always",
    "plugins": [
      "prettier-plugin-svelte"
    ],
    "overrides": [
      {
        "files": "*.svelte",
        "options": {
          "parser": "svelte"
        }
      }
    ]
  }
}
