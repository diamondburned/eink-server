{
  "width": 800,
  "height": 480,
  "password": null,
  "screenshot": {
    "cachedDurationSec": 60,
    "pageLoadDelaySec": 3,
    "cssFilter": "grayscale(1)",
    "dithering": {
      "algorithm": "none",
      "colors": 2
    }
  },
  "homeAssistant": {
    "endpoint": "https://ha.d14.place",
    "token": {
      "_file": "secrets/home-assistant-token"
    },
    "weather": "weather.forecast_home",
    "calendars": [
      "calendar.diamond",
      "calendar.diamondburned_google_com",
      "calendar.holidays_in_united_states",
      "calendar.birthdays"
    ],
    "selfBatteryEntity": "sensor.diamond_s_desk_e_ink_dashboard_battery_level"
  },
  "timeline": {
    "startHours": -4,
    "endHours": 8,
    "pixelsPerHour": 40
  },
  "showMinutes": "quarterly",
  "show24HourTime": true
}
